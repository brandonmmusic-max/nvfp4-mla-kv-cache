# Bakes the FULL proven-good DCP4 + nvfp4_ds_mla env + launch into the image itself,
# so `docker run --gpus all -v <ckpt>:/model verdictai/glm52-nvfp4-kv:v2` just works —
# no compose env block to drop, no wrong maxlen. Same nvfp4 kernel + reader as :v1.
FROM verdictai/glm52-nvfp4-kv:v1

# ---- full env (proven-good production merge; all-reduce OFF = boots at util 0.96) ----
ENV CUDA_VISIBLE_DEVICES=0,1,2,3 \
    CUDA_DEVICE_ORDER=PCI_BUS_ID \
    CUDA_DEVICE_MAX_CONNECTIONS=32 \
    CUTE_DSL_ARCH=sm_120a \
    OMP_NUM_THREADS=16 \
    PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True \
    SAFETENSORS_FAST_GPU=1 \
    NCCL_IB_DISABLE=1 \
    NCCL_P2P_LEVEL=SYS \
    NCCL_PROTO=LL,LL128,Simple \
    VLLM_USE_B12X_FP8_GEMM=1 \
    VLLM_USE_B12X_MOE=1 \
    VLLM_USE_B12X_SPARSE_INDEXER=1 \
    VLLM_USE_V2_MODEL_RUNNER=1 \
    B12X_W4A16_TC_DECODE=1 \
    B12X_MOE_FORCE_A16=1 \
    VLLM_DCP_GLOBAL_TOPK=1 \
    VLLM_DCP_SHARD_DRAFT=1 \
    VLLM_ENABLE_PCIE_ALLREDUCE=0 \
    VLLM_PCIE_ALLREDUCE_BACKEND=cpp \
    VLLM_PCIE_ONESHOT_ALLREDUCE_MAX_SIZE=64KB \
    B12X_DENSE_SPLITK_TURBO=1 \
    XDG_CACHE_HOME=/cache/jit \
    TRITON_CACHE_DIR=/cache/jit/triton \
    HYBRID_TIER=both \
    HYBRID_KEPT=b12x_nf3 \
    HYBRID_NF3=b12x_nf3 \
    HYBRID_B12X_MAX_TOKENS=4096 \
    HYBRID_MXFP8_NATIVE=1

# ---- full launch baked as default CMD (mount checkpoint at /model) ----
# nvfp4_ds_mla 4-bit MLA KV cache, TP4/DCP4, MTP-4, maxlen 196608, util 0.96.
CMD ["vllm","serve","/model",\
"--served-model-name","GLM-5.2","--host","0.0.0.0","--port","5001",\
"--trust-remote-code","--tensor-parallel-size","4",\
"--decode-context-parallel-size","4","--dcp-comm-backend","ag_rs","--dcp-kv-cache-interleave-size","1",\
"--kv-cache-dtype","nvfp4_ds_mla",\
"--attention-backend","B12X_MLA_SPARSE",\
"--moe-backend","b12x",\
"--load-format","fastsafetensors",\
"-cc.pass_config.fuse_allreduce_rms=True",\
"--gpu-memory-utilization","0.96",\
"--max-model-len","196608","--max-num-seqs","4","--max-num-batched-tokens","4096",\
"--max-cudagraph-capture-size","16",\
"--async-scheduling","--enable-chunked-prefill","--enable-prefix-caching",\
"--enable-auto-tool-choice","--tool-call-parser","glm47","--reasoning-parser","glm45",\
"--hf-overrides","{\"use_index_cache\":true,\"index_topk_pattern\":\"FFFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSSFSSS\"}",\
"--speculative-config","{\"method\":\"mtp\",\"num_speculative_tokens\":4,\"moe_backend\":\"b12x\",\"draft_sample_method\":\"probabilistic\"}"]
